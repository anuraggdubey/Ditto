# Supermemory — https://supermemory.ai/docs
SUPERMEMORY_API_KEY=

# Optional: use local Supermemory (docker-compose). Omit for cloud API.
# SUPERMEMORY_BASE_URL=http://localhost:6767

# LLM provider: anthropic | openai | groq
LLM_PROVIDER=groq

# Groq (when LLM_PROVIDER=groq) — fast, free tier available
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Session cookie signing (use a long random string in production)
SESSION_SECRET=change-me-to-a-random-secret
